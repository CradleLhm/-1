:root {
  --bg-color: #F5F5F0;
  --text-color: #1a1a1a;
  --accent-color: #000000;
  --font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background-color: var(--bg-color);
  color: var(--text-color);
  font-family: var(--font-family);
  overflow: hidden; /* Prevent native scroll to use our fluid floor logic */
  width: 100vw;
  height: 100vh;
}

#root {
  width: 100%;
  height: 100%;
}

/* Custom Scrollbar (Invisible but functional for future) */
::-webkit-scrollbar {
  display: none;
}

.blur-overlay {
  position: fixed;
  inset: 0;
  backdrop-filter: blur(8px);
  background: rgba(245, 245, 240, 0.4);
  z-index: 100;
}
